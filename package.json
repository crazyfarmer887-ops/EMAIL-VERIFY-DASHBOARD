{
  "name": "sandbox-website-template",
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@runablehq/website-runtime": "^0.10.0",
    "@types/pg": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "imapflow": "^1.4.7",
    "lucide-react": "^0.469.0",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@eslint/js": "^9.39.5",
    "@tailwindcss/vite": "^4.2.1",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "^8.63.0",
    "@typescript/native-preview": "^7.0.0-dev.20260306.1",
    "@vitejs/plugin-react": "5.1.4",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "wrangler": "^4.71.0"
  },
  "scripts": {
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --external:imapflow --external:tls --external:net --external:dns --external:pg --external:pg-native --outfile=dist/server.js",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --external:imapflow --external:tls --external:net --external:dns --external:pg --external:pg-native --outfile=dist/server.js",
    "check": "tsc -b",
    "dev": "tsx watch server.ts",
    "lint": "eslint .",
    "preview": "npm run build && node dist/server.js",
    "start": "node dist/server.js",
    "local": "npm run build && npm run start",
    "test": "npm run test:node && npm run test:vitest",
    "test:node": "node --test tests/auth-code-extractor.test.ts tests/database-config.test.ts tests/email-alerts.test.ts tests/email-auth.test.ts tests/email-blocklist.test.ts tests/gmail-client-secret.test.ts tests/gmail-sync-backoff.test.ts tests/mail-list-filter.test.ts tests/ui-contract.test.mjs",
    "test:vitest": "PGHOST=127.0.0.1 PGPORT=5432 PGDATABASE=test-emailcache PGUSER=test-emailapp PGPASSWORD=test-password-not-a-real-secret vitest run tests/api-security.test.ts tests/mail-ui-accessibility.test.tsx tests/manage-proxy.test.ts tests/manage-query.test.tsx tests/pin-store-reload.test.ts tests/pin-store-security.test.ts tests/simplelogin-aliases.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "type": "module"
}
